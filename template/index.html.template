    <section id="about" class="section-wrapper" style="position: relative;">
      <div class="glow-orb orb-2" aria-hidden="true"></div>
      <div class="container about-grid">
        <!-- Left Side: Clinic details -->
        <div class="about-content reveal-left">
          <div class="about-header">
            <span class="badge badge-cyan">Our Clinic</span>
            <h2 class="about-title">Welcoming Environment, Gentle Expertise</h2>
          </div>
          <p class="about-p">
            Located at the heart of {{CLINIC_CITY}} on {{CLINIC_ADDRESS_SHORT}}, <strong>{{CLINIC_NAME}}</strong> is a premier dental practice dedicated to providing state-of-the-art, accessible, and painless dental solutions. Our highly attentive medical team is known for turning anxious visits into comforting experiences.
          </p>
          <p class="about-p">
            We operate in strict compliance with the Medical and Dental Council of Nigeria (MDCN) guidelines, prioritizing meticulous sterilization, diagnostic precision, and complete financial transparency before any procedure starts.
          </p>

          <div class="values-list">
            <!-- Val 1 -->
            <div class="value-item">
              <div class="value-check" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" style="width: 18px; height: 18px;"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              </div>
              <div class="value-text">
                <h4>Accommodating & Gentle Care</h4>
                <p>We take time to explain options step-by-step, ensuring you feel completely relaxed and guided.</p>
              </div>
            </div>
            <!-- Val 2 -->
            <div class="value-item">
              <div class="value-check" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" style="width: 18px; height: 18px;"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              </div>
              <div class="value-text">
                <h4>HMO & Insurance Friendly</h4>
                <p>We work directly with top local insurance providers to make your high-quality treatments affordable.</p>
              </div>
            </div>
          </div>
        </div>

