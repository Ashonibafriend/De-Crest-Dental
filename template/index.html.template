  <!-- ==========================================
       ADVANCED FEATURE: MULTI-STEP PATIENT INTAKE FORM MODAL
       ========================================== -->
  <div id="intake-modal-overlay" class="modal-overlay" aria-hidden="true" role="dialog">
    <div class="modal-content" style="max-width: 600px; padding: 2rem;">
      <button id="intake-modal-close" class="btn-icon modal-close-btn" aria-label="Close intake modal">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 20px; height: 20px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Step Progress Bar -->
      <div class="intake-progress-wrapper" style="margin-bottom: 1.5rem;">
        <h3 style="font-size: 1.25rem; font-weight: 700; color: var(--color-text); margin-bottom: var(--space-sm);">New Patient Intake Wizard</h3>
        <div class="intake-progress-bar" style="display: flex; justify-content: space-between; position: relative;">
          <div class="progress-line" style="position: absolute; top: 50%; left: 0; right: 0; height: 3px; background-color: var(--color-border); z-index: 1; transform: translateY(-50%);">
            <div id="intake-progress-fill" style="height: 100%; width: 0%; background-color: var(--color-cta); transition: width 0.3s ease;"></div>
          </div>
          <div class="progress-step active" data-step="1">1</div>
          <div class="progress-step" data-step="2">2</div>
          <div class="progress-step" data-step="3">3</div>
          <div class="progress-step" data-step="4">4</div>
        </div>
        <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--color-text-muted); margin-top: 6px;">
          <span>Personal Info</span>
          <span>Medical History</span>
          <span>Dental Profile</span>
          <span>Sign & Consent</span>
        </div>
      </div>

      <!-- Form steps -->
      <form id="patient-intake-form" novalidate>
        
        <!-- Step 1: Personal Details -->
        <div class="intake-step active" data-step="1">
          <h4 style="margin-bottom: 1rem; color: var(--color-text); font-size: 1rem;">Step 1: Patient Personal Details</h4>
          <div class="form-grid-2col" style="margin-bottom: var(--space-md);">
            <div class="form-group-v8">
              <label class="form-label-v8" for="intake-dob">Date of Birth</label>
              <input class="form-input-v8" type="date" id="intake-dob" required>
            </div>
            <div class="form-group-v8">
              <label class="form-label-v8" for="intake-gender">Gender Identity</label>
              <select class="form-input-v8" id="intake-gender" required>
                <option value="" disabled selected>Select...</option>
                <option value="Female">Female</option>
                <option value="Male">Male</option>
                <option value="Non-Binary">Non-binary</option>
                <option value="Prefer not to say">Prefer not to say</option>
              </select>
            </div>
          </div>
          <div class="form-grid-2col">
            <div class="form-group-v8">
              <label class="form-label-v8" for="intake-emerg-name">Emergency Contact Name</label>
              <input class="form-input-v8" type="text" id="intake-emerg-name" placeholder="E.g. Femi Adebayo" required>
            </div>
            <div class="form-group-v8">
              <label class="form-label-v8" for="intake-emerg-phone">Emergency Phone</label>
              <input class="form-input-v8" type="tel" id="intake-emerg-phone" placeholder="E.g. 0806 000 0000" required>
            </div>
          </div>
        </div>

        <!-- Step 2: Medical History -->
        <div class="intake-step" data-step="2">
          <h4 style="margin-bottom: 1rem; color: var(--color-text); font-size: 1rem;">Step 2: Medical Background History</h4>
          <div class="form-group-v8">
            <label class="form-label-v8" for="intake-allergies">Drug / Substance Allergies (if any)</label>
            <input class="form-input-v8" type="text" id="intake-allergies" placeholder="E.g. Penicillin, Latex (leave blank if none)">
          </div>
          <div class="form-group-v8">
            <label class="form-label-v8" for="intake-meds">Active Medications (if any)</label>
            <input class="form-input-v8" type="text" id="intake-meds" placeholder="List active drugs or capsules being taken">
          </div>
          <div style="display: flex; flex-direction: column; gap: 8px; margin-top: 10px;">
            <label class="form-label-v8">Check all medical conditions that apply:</label>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; font-size: 0.85rem; color: var(--color-text-muted);">
              <label style="display: flex; gap: 6px; align-items: center; cursor: pointer;"><input type="checkbox" id="cond-heart" style="accent-color: var(--color-cta);"> Heart Conditions</label>
              <label style="display: flex; gap: 6px; align-items: center; cursor: pointer;"><input type="checkbox" id="cond-diabetes" style="accent-color: var(--color-cta);"> Diabetes</label>
              <label style="display: flex; gap: 6px; align-items: center; cursor: pointer;"><input type="checkbox" id="cond-bp" style="accent-color: var(--color-cta);"> High Blood Pressure</label>
              <label style="display: flex; gap: 6px; align-items: center; cursor: pointer;"><input type="checkbox" id="cond-preg" style="accent-color: var(--color-cta);"> Pregnant</label>
            </div>
          </div>
        </div>

        <!-- Step 3: Dental Profile -->
        <div class="intake-step" data-step="3">
          <h4 style="margin-bottom: 1rem; color: var(--color-text); font-size: 1rem;">Step 3: Dental Health Profile</h4>
          <div class="form-group-v8">
            <label class="form-label-v8" for="intake-last-visit">Last Dental Checkup or Scaling</label>
            <select class="form-input-v8" id="intake-last-visit" required>
              <option value="" disabled selected>Select...</option>
              <option value="Under 6 months">Within the last 6 months</option>
              <option value="6-12 months">6 to 12 months ago</option>
              <option value="Over a year">More than a year ago</option>
              <option value="Never">This is my first dental visit</option>
            </select>
          </div>
          <div style="display: flex; flex-direction: column; gap: 8px; margin-top: var(--space-xs); margin-bottom: var(--space-sm);">
            <label style="display: flex; gap: 6px; align-items: center; cursor: pointer; font-size: 0.88rem; color: var(--color-text);"><input type="checkbox" id="dent-bleeding" style="accent-color: var(--color-cta);"> My gums bleed when brushing or flossing.</label>
            <label style="display: flex; gap: 6px; align-items: center; cursor: pointer; font-size: 0.88rem; color: var(--color-text);"><input type="checkbox" id="dent-pain" style="accent-color: var(--color-cta);"> I am experiencing acute mouth or tooth pain.</label>
          </div>
          <div class="form-group-v8">
            <label class="form-label-v8" for="intake-fear">Do you experience dental anxiety/fear? (Scale 1-5)</label>
            <input type="range" id="intake-fear" min="1" max="5" value="1" style="accent-color: var(--color-cta); cursor: pointer;">
            <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--color-text-muted); padding: 0 4px;">
              <span>No fear (1)</span>
              <span>Moderate</span>
              <span>Severe anxiety (5)</span>
            </div>
          </div>
        </div>

        <!-- Step 4: Sign & Consent -->
        <div class="intake-step" data-step="4">
          <h4 style="margin-bottom: 1rem; color: var(--color-text); font-size: 1rem;">Step 4: Digital Consent & Signature</h4>
          <p style="font-size: 0.82rem; color: var(--color-text-muted); line-height: 1.5; margin-bottom: var(--space-md);">
            I hereby certify that all medical history and details provided are accurate to the best of my knowledge. I consent to diagnostic assessments (oral examination, cleanings, digital X-rays) performed by De-Crest Dental practitioners.
          </p>
          <div class="form-group-v8">
            <label class="form-label-v8" for="intake-sig-name">Electronic Signature (Type Full Name)</label>
            <input class="form-input-v8" type="text" id="intake-sig-name" placeholder="Type your name to sign" required>
          </div>
          <div style="display: flex; align-items: center; gap: 8px; margin-top: var(--space-sm);">
            <input type="checkbox" id="intake-consent" required style="accent-color: var(--color-cta); width: 16px; height: 16px; cursor: pointer;">
            <label for="intake-consent" style="font-size: 0.82rem; color: var(--color-text); cursor: pointer; user-select: none;">I accept electronic consent standards.</label>
          </div>
        </div>

        <!-- Form Navigation Footer -->
        <div style="display: flex; justify-content: space-between; border-top: 1px solid var(--color-border); padding-top: var(--space-md); margin-top: var(--space-lg);">
          <button type="button" id="intake-prev" class="btn btn-secondary" style="display: none; padding: 0.5rem 1.25rem;">Back</button>
          <span style="flex-grow: 1;"></span>
          <button type="button" id="intake-next" class="btn btn-primary" style="padding: 0.5rem 1.25rem;">Continue &rarr;</button>
          <button type="submit" id="intake-submit" class="btn btn-primary" style="display: none; padding: 0.5rem 1.25rem; background-color: var(--color-cta);">Submit Intake</button>
        </div>
      </form>
    </div>
  </div>

  <!-- INTAKE SUCCESS DRAWER SPLASH -->
  <div id="intake-success-overlay" class="success-overlay-splash" aria-hidden="true">
    <div class="modal-content" style="text-align: center; align-items: center; max-width: 440px;">
      <div class="success-icon-badge" style="background-color: rgba(5, 150, 105, 0.1); color: var(--color-cta); width: 64px; height: 64px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: var(--space-sm); animation: pulse-ring-emerald 2s infinite;" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 32px; height: 32px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
      </div>
      <h3 style="font-size: 1.4rem; color: var(--color-cta); font-weight: 700; margin-bottom: 2px;">Intake Submitted!</h3>
      <p style="color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: var(--space-md);">
        Your digital intake docket has been successfully synced and logged inside your clinical portal folder.
      </p>
      <button type="button" id="intake-success-close" class="btn btn-primary" style="width: 100%;">Return to Portal</button>
    </div>
  </div>

  <!-- ==========================================
       ADVANCED FEATURE: INTERACTIVE FLOATING LIVE CHAT WIDGET
       ========================================== -->
  <div id="live-chat-widget" class="chat-widget-wrapper">
    <!-- Bubble click indicator -->
    <button id="chat-bubble-toggle" class="chat-bubble-btn" aria-label="Open clinical virtual support assistant" title="Virtual Support">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="chat-bubble-icon" style="width: 24px; height: 24px;">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.076-4.076a1.526 1.526 0 011.037-.443 48.282 48.282 0 005.68-.494c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
      </svg>
      <span class="chat-unread-dot" aria-hidden="true"></span>
    </button>

    <!-- Chat Card Body panel -->
    <div id="chat-window-panel" class="chat-window-panel" aria-hidden="true">
      <!-- Chat Header -->
      <div class="chat-header">
        <div style="display: flex; align-items: center; gap: 8px;">
          <div class="chat-avatar" style="background-color: var(--color-cta); color: #FFFFFF; font-weight:700; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.85rem;">DC</div>
          <div>
            <h4 style="margin: 0; font-size: 0.9rem; font-weight: 700; color: #FFFFFF; line-height:1.2;">De-Crest Assistant</h4>
            <span style="font-size: 0.68rem; color: rgba(255, 255, 255, 0.85); display: flex; align-items: center; gap: 4px;">
              <span style="width: 6px; height: 6px; border-radius: 50%; background-color: #10B981; display: inline-block;"></span>
              Virtual Guide · Active
            </span>
          </div>
        </div>
        <button id="chat-close-btn" class="btn-icon" aria-label="Close chat window" title="Close Chat" style="color: #FFFFFF; padding: var(--space-xs); hover: background-color: rgba(255, 255, 255, 0.1);">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 18px; height: 18px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Chat Messages Scroll Container -->
      <div id="chat-messages-container" class="chat-messages-container">
        <!-- Welcoming Bot bubble -->
        <div class="chat-message-row bot-msg-row">
          <div class="chat-msg-bubble">
            Hello! Welcoming you to De-Crest Dental Clinic Virtual Support. How can we help you today? Select one of the quick topics below or start typing.
          </div>
        </div>
        
        <!-- Live typing indicator template (hidden by default) -->
        <div id="chat-typing-indicator" class="chat-message-row bot-msg-row hidden">
          <div class="chat-msg-bubble typing-bubble">
            <span class="typing-dot"></span>
            <span class="typing-dot"></span>
            <span class="typing-dot"></span>
          </div>
        </div>
      </div>

      <!-- Quick Reply Action Options -->
      <div id="chat-quick-replies" class="chat-quick-replies">
        <button class="chat-reply-chip" data-topic="hours">Clinic Hours</button>
        <button class="chat-reply-chip" data-topic="pricing">Pricing & HMO</button>
        <button class="chat-reply-chip" data-topic="location">Location & Map</button>
        <button class="chat-reply-chip" data-topic="intake">Fill Intake Form</button>
        <button class="chat-reply-chip" data-topic="book">Book Consultation</button>
      </div>

      <!-- Chat Input Field Footer -->
      <form id="chat-input-form" class="chat-input-form">
        <input type="text" id="chat-text-input" class="chat-text-input" placeholder="Type a message..." required autocomplete="off" aria-label="Message text input">
        <button type="submit" class="chat-send-btn" aria-label="Send message" title="Send">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" style="width: 16px; height: 16px;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
          </svg>
        </button>
      </form>
    </div>
  </div>

  <!-- Scripts -->
  <script src="index.js"></script>
</body>
</html>
