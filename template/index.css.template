}

.sparkle-3 {
  width: 28px;
  height: 28px;
  top: 45%;
  left: 20%;
  animation: sparkle-effect 2.2s infinite ease-in-out;
  animation-delay: 1.2s;
}

@keyframes sparkle-effect {
  0%, 100% {
    transform: scale(0.2) rotate(0deg);
    opacity: 0;
  }
  50% {
    transform: scale(1.1) rotate(180deg);
    opacity: 1;
