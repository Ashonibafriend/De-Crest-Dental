@import url('https://fonts.googleapis.com/css2?family=Figtree:wght@300;400;500;600;700&family=Noto+Sans:wght@300;400;500;700&display=swap');

/* ==========================================
   1. DESIGN SYSTEM VARIABLES & THEMING
   ========================================== */
:root {
  /* Colors - Light Theme default */
  --color-primary: {{THEME_PRIMARY}};
  --color-primary-rgb: {{THEME_PRIMARY_RGB}};
  --color-primary-hover: {{THEME_PRIMARY_HOVER}};
  --color-secondary: {{THEME_PRIMARY}};
  --color-cta: {{THEME_CTA}};
  --color-cta-hover: {{THEME_CTA_HOVER}};
  --color-bg: #ECFEFF;
  --color-bg-card: #FFFFFF;
  --color-bg-glass: rgba(255, 255, 255, 0.75);
  --color-text: #164E63;
  --color-text-muted: #475569;
  --color-border: #CFFAFE;
  --color-border-hover: #A5F3FC;
  --color-ring: rgba(8, 145, 178, 0.3);
  --color-danger: #EF4444;
  --color-danger-hover: #DC2626;

  /* Typography */
  --font-heading: 'Figtree', sans-serif;
  --font-body: 'Noto Sans', sans-serif;

  /* Spacing Tokens */
  --space-xs: 0.25rem;  /* 4px */
  --space-sm: 0.5rem;   /* 8px */
  --space-md: 1rem;     /* 16px */
  --space-lg: 1.5rem;   /* 24px */
  --space-xl: 2rem;     /* 32px */
  --space-2xl: 3rem;    /* 48px */
  --space-3xl: 4.5rem;  /* 72px */

  /* Border Radii */
  --radius-xs: 4px;
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 24px;
  --radius-full: 9999px;

  /* Shadow Depths */
  --shadow-sm: 0 1px 3px rgba(8, 145, 178, 0.05), 0 1px 2px rgba(8, 145, 178, 0.03);
  --shadow-md: 0 8px 24px rgba(8, 145, 178, 0.08), 0 2px 8px rgba(8, 145, 178, 0.04);
  --shadow-lg: 0 16px 40px rgba(8, 145, 178, 0.12), 0 4px 12px rgba(8, 145, 178, 0.06);
  --shadow-xl: 0 24px 60px rgba(8, 145, 178, 0.16), 0 8px 24px rgba(8, 145, 178, 0.08);

  /* Layout Constrains */
  --max-width: 1280px;
}

[data-theme="dark"] {
  /* Colors - Dark Theme overrides (Premium Greyscale Zinc) */
  --color-primary: #22D3EE;
  --color-primary-rgb: 34, 211, 238;
  --color-primary-hover: #67E8F9;
  --color-secondary: #27272A;
  --color-cta: #10B981;
  --color-cta-hover: #059669;
  --color-bg: #09090B;
  --color-bg-card: #18181B;
  --color-bg-glass: rgba(9, 9, 11, 0.85);
  --color-text: #FAFAFA;
  --color-text-muted: #A1A1AA;
  --color-border: #27272A;
  --color-border-hover: #3F3F46;
  --color-ring: rgba(34, 211, 238, 0.15);
  --color-danger: #EF4444;
  --color-danger-hover: #DC2626;
}

/* ==========================================
   2. RESET & BASE ACCESSIBILITY STYLES
   ========================================== */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
  scroll-padding-top: 6.5rem; /* Offsets scroll targeting to clear floating navbar */
  font-size: 16px;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

body {
  font-family: var(--font-body);
  background-color: var(--color-bg);
  color: var(--color-text);
  line-height: 1.6;
  transition: background-color 300ms ease, color 300ms ease;
  overflow-x: hidden;
  position: relative;
}

/* Accessible focus styling for all keyboard interactions */
:focus-visible {
  outline: 3px solid var(--color-primary);
  outline-offset: 4px;
}

/* Accessible Skip Link */
.skip-link {
  position: absolute;
  top: -100px;
  left: 1.5rem;
  background-color: var(--color-cta);
  color: #FFFFFF;
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-sm);
  font-weight: 600;
  z-index: 10000;
  text-decoration: none;
  transition: top 200ms ease;
  box-shadow: var(--shadow-lg);
}

.skip-link:focus {
  top: 1.5rem;
}

h1, h2, h3, h4, h5, h6 {
  font-family: var(--font-heading);
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: -0.02em;
}

img {
  max-width: 100%;
  height: auto;
  display: block;
}

ul {
  list-style: none;
}

a {
  color: inherit;
  text-decoration: none;
  transition: color var(--transition-fast);
}

/* Utility Containers */
.container {
  width: 100%;
  max-width: var(--max-width);
  margin-left: auto;
  margin-right: auto;
  padding-left: var(--space-lg);
  padding-right: var(--space-lg);
}

@media (min-width: 768px) {
  .container {
    padding-left: var(--space-xl);
    padding-right: var(--space-xl);
  }
}

/* Reusable Section spacing wrapper */
.section-wrapper {
  padding: 5rem 0;
  border-top: 1px solid rgba(var(--color-primary-rgb), 0.1);
  overflow: hidden;
}

.section-header {
  text-align: center;
  max-width: 680px;
  margin: 0 auto 3rem auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-sm);
}

.section-title {
  font-size: clamp(2rem, 4vw, 2.5rem);
  color: var(--color-text);
  font-weight: 800;
}

.section-subtitle {
  color: var(--color-text-muted);
  font-size: 1.05rem;
}

/* ==========================================
   3. REUSABLE COMPONENTS (Buttons, Badges, etc.)
   ========================================== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
  font-family: var(--font-heading);
  font-weight: 600;
  padding: 0.75rem 1.5rem;
  border-radius: var(--radius-md);
  border: 2px solid transparent;
  cursor: pointer;
  white-space: nowrap;
  transition: all var(--transition-normal);
  font-size: 0.95rem;
  position: relative;
  overflow: hidden;
}

.btn-primary {
  background-color: var(--color-cta);
  color: #FFFFFF;
}

.btn-primary:hover {
  background-color: var(--color-cta-hover);
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(5, 150, 105, 0.3);
}

.btn-primary:active {
  transform: translateY(0);
}

.btn-secondary {
  background-color: transparent;
  border-color: var(--color-primary);
  color: var(--color-primary);
}

.btn-secondary:hover {
  background-color: rgba(8, 145, 178, 0.08);
  transform: translateY(-2px);
}

.btn-secondary:active {
  transform: translateY(0);
}

.btn-icon {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--color-text);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
  padding: var(--space-xs);
  transition: background-color var(--transition-fast), color var(--transition-fast);
}

.btn-icon:hover {
  background-color: rgba(var(--color-primary-rgb), 0.1);
  color: var(--color-primary);
}

.badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  padding: 0.25rem 0.75rem;
  border-radius: var(--radius-full);
  font-family: var(--font-heading);
  font-weight: 600;
  font-size: 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.badge-cyan {
  background-color: rgba(8, 145, 178, 0.1);
  color: var(--color-primary);
  border: 1px solid rgba(8, 145, 178, 0.2);
}

.badge-emerald {
  background-color: rgba(5, 150, 105, 0.1);
  color: var(--color-cta);
  border: 1px solid rgba(5, 150, 105, 0.2);
}

.live-badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-sm);
  background-color: var(--color-bg-card);
  padding: 0.5rem 1rem;
  border-radius: var(--radius-full);
  font-family: var(--font-heading);
  font-size: 0.85rem;
  font-weight: 600;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--color-border);
  transition: all var(--transition-normal);
}

.live-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  display: inline-block;
  position: relative;
}

.live-dot.active {
  background-color: #10B981;
}

.live-dot.active::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #10B981;
  animation: pulse-ring 1.5s infinite ease-in-out;
}

.live-dot.inactive {
  background-color: #F59E0B;
}

.live-dot.inactive::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: #F59E0B;
  animation: pulse-ring-slow 2s infinite ease-in-out;
}

/* ==========================================
   4. FLOATING HEADER & NAVIGATION
   ========================================== */
.header-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  padding: var(--space-md) 0;
  pointer-events: none;
}

.header-container {
  pointer-events: auto;
  background-color: var(--color-bg-glass);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  max-width: var(--max-width);
  margin: 0 auto;
  box-shadow: var(--shadow-md);
  transition: all var(--transition-slow);
}

.header-scrolled {
  border-radius: 0;
  max-width: 100%;
  border-left: none;
  border-right: none;
  border-top: none;
  box-shadow: var(--shadow-lg);
}

.navbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem var(--space-lg);
  position: relative;
}

.nav-brand {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  font-family: var(--font-heading);
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--color-text);
}

.brand-logo-img {
  height: 36px;
  width: auto;
  border-radius: 4px;
}

.nav-brand span {
  background: linear-gradient(135deg, var(--color-primary) 30%, var(--color-cta) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.nav-menu {
  display: none;
}

@media (min-width: 992px) {
  .nav-menu {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }
}

.nav-link {
  font-family: var(--font-heading);
  font-weight: 500;
  font-size: 0.9rem;
  color: var(--color-text-muted);
  position: relative;
  padding: 0.25rem 0;
}

.nav-link::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  width: 0;
  height: 2px;
  background-color: var(--color-primary);
  transition: width var(--transition-normal);
}

.nav-link:hover {
  color: var(--color-text);
}

.nav-link:hover::after {
  width: 100%;
}

.nav-link.active {
  color: var(--color-primary);
  font-weight: 600;
}

.nav-link.active::after {
  width: 100%;
}

.nav-actions {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}

.menu-btn {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  width: 24px;
  height: 18px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  z-index: 1100;
}

@media (min-width: 992px) {
  .menu-btn {
    display: none;
  }
}

@media (max-width: 991px) {
  .nav-call-btn,
  .nav-book-btn {
    display: none;
  }
}

.menu-btn span {
  display: block;
  width: 100%;
  height: 2px;
  background-color: var(--color-text);
  border-radius: var(--radius-xs);
  transition: transform var(--transition-normal), opacity var(--transition-fast);
}

.menu-btn.open span:nth-child(1) {
  transform: translateY(8px) rotate(45deg);
}

.menu-btn.open span:nth-child(2) {
  opacity: 0;
}

.menu-btn.open span:nth-child(3) {
  transform: translateY(-8px) rotate(-45deg);
}

.mobile-nav {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background-color: var(--color-bg-card);
  border-bottom-left-radius: var(--radius-md);
  border-bottom-right-radius: var(--radius-md);
  border: 1px solid var(--color-border);
  border-top: none;
  box-shadow: var(--shadow-lg);
  padding: var(--space-lg);
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  opacity: 0;
  transform: translateY(-10px);
  pointer-events: none;
  transition: opacity var(--transition-normal), transform var(--transition-normal);
  z-index: 999;
}

.mobile-nav.open {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

.mobile-nav .nav-link {
  padding: var(--space-sm) 0;
  display: block;
  border-bottom: 1px solid rgba(var(--color-primary-rgb), 0.05);
}

.mobile-nav .nav-link:last-of-type {
  border-bottom: none;
}

/* ==========================================
   5. SECTION 1: HERO SECTION
   ========================================== */
.hero-section {
  padding-top: 8rem;
  padding-bottom: 3rem;
  position: relative;
  overflow: hidden;
}

.hero-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-2xl);
  align-items: center;
}

@media (min-width: 992px) {
  .hero-grid {
    grid-template-columns: 1.15fr 0.85fr;
  }
}

.hero-content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--space-md);
}

.hero-title {
  font-size: clamp(2.5rem, 5vw, 3.8rem);
  color: var(--color-text);
  font-weight: 800;
  margin-top: var(--space-sm);
}

.hero-title span {
  display: block;
  color: var(--color-primary);
  background: linear-gradient(135deg, var(--color-primary) 30%, var(--color-cta) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.hero-description {
  font-size: clamp(1rem, 2vw, 1.15rem);
  color: var(--color-text-muted);
  max-width: 580px;
  margin-bottom: var(--space-sm);
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-md);
  margin-bottom: var(--space-sm);
}

.hero-visual {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}

.hero-image-wrapper {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-xl);
  border: 4px solid var(--color-bg-card);
  aspect-ratio: 4 / 3;
  width: 100%;
  max-width: 500px;
}

.hero-svg-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(8, 145, 178, 0.08) 0%, rgba(34, 211, 238, 0.15) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-svg-placeholder svg {
  width: 120px;
  height: 120px;
  color: var(--color-primary);
  animation: float 6s ease-in-out infinite;
}

/* ==========================================
   6. SECTION 2: TRUST BAR
   ========================================== */
.trust-bar {
  padding: 1.5rem 0;
  position: relative;
  z-index: 10;
}

.trust-bar-container {
  background-color: var(--color-bg-glass);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 1.5rem;
  box-shadow: var(--shadow-md);
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}

@media (min-width: 768px) {
  .trust-bar-container {
    grid-template-columns: repeat(4, 1fr);
  }
}

.trust-item {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.trust-icon {
  font-size: 1.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-cta);
  flex-shrink: 0;
}

.trust-text-box {
  display: flex;
  flex-direction: column;
}

.trust-title {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 1.05rem;
  color: var(--color-text);
}

.trust-desc {
  font-size: 0.8rem;
  color: var(--color-text-muted);
  font-weight: 500;
}

/* ==========================================
   7. SECTION 3: ABOUT CLINIC
   ========================================== */
.about-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  align-items: center;
}

@media (min-width: 992px) {
  .about-grid {
    grid-template-columns: 1.05fr 0.95fr;
  }
}

.about-content {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.about-header {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.about-title {
  font-size: clamp(1.8rem, 3.5vw, 2.3rem);
  color: var(--color-text);
}

.about-p {
  color: var(--color-text-muted);
  font-size: 1rem;
}

.values-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
  margin-top: var(--space-xs);
}

.value-item {
  display: flex;
  gap: var(--space-sm);
  align-items: flex-start;
}

.value-check {
  color: var(--color-primary);
  flex-shrink: 0;
  margin-top: 2px;
}

.value-text h4 {
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 2px;
}

.value-text p {
  font-size: 0.88rem;
  color: var(--color-text-muted);
}

.about-visual {
  position: relative;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
  border: 4px solid var(--color-bg-card);
  aspect-ratio: 4 / 3;
}

.about-svg-box {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, rgba(5, 150, 105, 0.08) 0%, rgba(8, 145, 178, 0.15) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.about-svg-box svg {
  width: 100px;
  height: 100px;
  color: var(--color-cta);
  animation: float 5s ease-in-out infinite alternate;
}

/* ==========================================
   8. SECTION 4: SERVICES SECTION
   ========================================== */
.services-section {
  background-color: rgba(var(--color-primary-rgb), 0.02);
}

.services-grid-8 {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-lg);
}

@media (min-width: 576px) {
  .services-grid-8 {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 992px) {
  .services-grid-8 {
    grid-template-columns: repeat(4, 1fr);
  }
}

.service-card-v8 {
  background-color: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 1.5rem;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  transition: all var(--transition-normal);
}

.service-card-v8:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
  border-color: var(--color-border-hover);
}

.service-icon-v8 {
  width: 44px;
  height: 44px;
  background-color: rgba(var(--color-primary-rgb), 0.08);
  color: var(--color-primary);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--transition-normal);
}

.service-card-v8:hover .service-icon-v8 {
  background-color: var(--color-primary);
  color: #FFFFFF;
}

.service-title-v8 {
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--color-text);
}

.service-desc-v8 {
  font-size: 0.88rem;
  color: var(--color-text-muted);
  flex-grow: 1;
  line-height: 1.5;
}

.service-btn-v8 {
  align-self: flex-start;
  font-family: var(--font-heading);
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--color-primary);
  background: none;
  border: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  padding: 0;
  transition: color var(--transition-fast);
}

.service-btn-v8:hover {
  color: var(--color-primary-hover);
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  z-index: 3000;
  display: flex;
  visibility: hidden;
  opacity: 0;
  align-items: center;
  justify-content: center;
  padding: var(--space-md);
  transition: opacity var(--transition-normal), visibility var(--transition-normal);
}

.modal-overlay.active {
  visibility: visible;
  opacity: 1;
}

.modal-content {
  background-color: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: 2rem;
  box-shadow: var(--shadow-xl);
  max-width: 500px;
  width: 100%;
  transform: translateY(-20px);
  transition: transform var(--transition-normal) cubic-bezier(0.16, 1, 0.3, 1);
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
