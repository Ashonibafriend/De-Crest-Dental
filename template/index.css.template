/* ==========================================
   23. ACCELERATED DENTAL COMPONENT STYLES
   ========================================== */

/* Page Preloader Overlay */
.page-preloader {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: var(--color-bg);
  z-index: 99999;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.5s ease, visibility 0.5s ease;
  visibility: visible;
}
.page-preloader[aria-hidden="true"] {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}
.preloader-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--space-md);
  max-width: 300px;
  width: 90%;
}
.preloader-logo-frame {
  width: 80px;
  height: 80px;
  border-radius: var(--radius-lg);
  background: linear-gradient(135deg, rgba(8, 145, 178, 0.1) 0%, rgba(5, 150, 105, 0.1) 100%);
  border: 2px solid var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-lg);
  animation: pulse-ring-emerald 2s infinite;
}
.preloader-logo-img {
  width: 50px;
  height: 50px;
  object-fit: contain;
  animation: preloader-logo-pulse 2s infinite ease-in-out;
}
@keyframes preloader-logo-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15) rotate(90deg); }
}
.preloader-title {
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--color-text);
  margin: 0;
  letter-spacing: -0.02em;
}
.preloader-badge {
  font-family: var(--font-heading);
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--color-primary);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.preloader-bar-bg {
  width: 100%;
  height: 4px;
  background-color: var(--color-border);
  border-radius: var(--radius-full);
  overflow: hidden;
  margin-top: var(--space-sm);
}
.preloader-bar-fill {
  width: 0%;
  height: 100%;
  background-color: var(--color-cta);
  border-radius: var(--radius-full);
  transition: width 1.2s cubic-bezier(0.16, 1, 0.3, 1);
}

/* Floating Live Chat Widget */
.chat-widget-wrapper {
  position: fixed;
  bottom: 24px;
  right: 24px;
  z-index: 1500;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}
.chat-bubble-btn {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-cta) 100%);
  border: none;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: var(--shadow-xl);
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  position: relative;
}
.chat-bubble-btn:hover {
  transform: scale(1.08) translateY(-2px);
  box-shadow: 0 16px 32px rgba(8, 145, 178, 0.3);
}
.chat-unread-dot {
  position: absolute;
  top: 2px;
  right: 2px;
  width: 12px;
  height: 12px;
  background-color: var(--color-danger);
  border: 2px solid var(--color-bg-card);
  border-radius: 50%;
  animation: pulse-ring-red 2.5s infinite;
}
@keyframes pulse-ring-red {
  0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7); }
  70% { box-shadow: 0 0 0 6px rgba(239, 68, 68, 0); }
  100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
}
.chat-window-panel {
  position: absolute;
  bottom: 80px;
  right: 0;
  width: 360px;
  max-width: calc(100vw - 48px);
  height: 480px;
  max-height: calc(100vh - 120px);
  background-color: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-xl);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transform: translateY(20px) scale(0.95);
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  z-index: 100;
}
.chat-window-panel.active {
  transform: translateY(0) scale(1);
  opacity: 1;
  pointer-events: auto;
}
.chat-header {
  padding: 1rem 1.25rem;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
  color: #FFFFFF;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}
.chat-messages-container {
  flex-grow: 1;
  overflow-y: auto;
  padding: 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  background-color: rgba(var(--color-primary-rgb), 0.01);
}
.chat-message-row {
  display: flex;
  width: 100%;
}
.bot-msg-row {
  justify-content: flex-start;
}
.user-msg-row {
  justify-content: flex-end;
}
.chat-msg-bubble {
  max-width: 80%;
  padding: 0.75rem 1rem;
  border-radius: var(--radius-md);
  font-size: 0.88rem;
  line-height: 1.5;
  box-shadow: var(--shadow-sm);
  animation: fade-in-up 0.25s ease;
}
.bot-msg-row .chat-msg-bubble {
  background-color: var(--color-bg);
  color: var(--color-text);
  border-bottom-left-radius: var(--radius-xs);
  border: 1px solid var(--color-border);
}
.user-msg-row .chat-msg-bubble {
  background-color: var(--color-cta);
  color: #FFFFFF;
  border-bottom-right-radius: var(--radius-xs);
}
.typing-bubble {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 0.6rem 1rem;
}
.typing-dot {
  width: 6px;
  height: 6px;
  background-color: var(--color-text-muted);
  border-radius: 50%;
  opacity: 0.4;
  animation: typing-bounce 1.4s infinite ease-in-out;
}
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes typing-bounce {
  0%, 100% { transform: translateY(0); opacity: 0.4; }
  50% { transform: translateY(-4px); opacity: 1; }
}
.chat-quick-replies {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  padding: 0.75rem 1.25rem;
  background-color: var(--color-bg-card);
  border-top: 1px solid var(--color-border);
}
.chat-reply-chip {
  padding: 0.4rem 0.8rem;
  border-radius: var(--radius-full);
  background-color: rgba(var(--color-primary-rgb), 0.05);
  border: 1px solid var(--color-border);
  color: var(--color-primary);
  font-size: 0.78rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
}
.chat-reply-chip:hover {
  background-color: var(--color-primary);
  color: #FFFFFF;
  border-color: var(--color-primary);
  transform: translateY(-1px);
}
.chat-input-form {
  display: flex;
  padding: 0.75rem 1.25rem;
  background-color: var(--color-bg-card);
  border-top: 1px solid var(--color-border);
  gap: 8px;
}
.chat-text-input {
  flex-grow: 1;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-full);
  padding: 0.6rem 1rem;
  font-size: 0.88rem;
  background-color: var(--color-bg);
  color: var(--color-text);
  outline: none;
  transition: border-color 0.2s ease;
}
.chat-text-input:focus {
  border-color: var(--color-primary);
}
.chat-send-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background-color: var(--color-cta);
  color: #FFFFFF;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background-color 0.2s ease;
}
.chat-send-btn:hover {
  background-color: var(--color-cta-hover);
}

/* Patient Intake Wizard modal step progress and layout */
.intake-progress-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  margin: 1.5rem 0 0.5rem 0;
}
.progress-step {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background-color: var(--color-bg-card);
  border: 2px solid var(--color-border);
  color: var(--color-text-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 0.85rem;
  z-index: 5;
  transition: all 0.3s ease;
}
.progress-step.active {
  border-color: var(--color-primary);
  background-color: var(--color-primary);
  color: #FFFFFF;
  box-shadow: 0 0 10px rgba(8, 145, 178, 0.4);
}
.progress-step.completed {
  border-color: var(--color-cta);
  background-color: var(--color-cta);
  color: #FFFFFF;
}
.intake-step {
  display: none;
  animation: fade-in-up 0.3s ease-out;
}
.intake-step.active {
  display: block;
}

/* HMO insurance list */
.hmo-logo-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}
@media (min-width: 576px) {
  .hmo-logo-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}
.hmo-card {
  background-color: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-shadow: var(--shadow-sm);
  transition: all 0.3s ease;
  min-height: 60px;
}
.hmo-card:hover {
  transform: translateY(-2px);
  border-color: var(--color-primary);
  box-shadow: var(--shadow-md);
}
.hmo-card span {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 0.85rem;
  color: var(--color-text);
  letter-spacing: -0.01em;
}

/* Emergency Contact sticky/floating banner */
.emergency-contact-banner {
  background: linear-gradient(135deg, #EF4444 0%, #B91C1C 100%);
  color: #FFFFFF;
  border-radius: var(--radius-lg);
  padding: 1.5rem 2rem;
  box-shadow: var(--shadow-xl);
  margin-top: 3rem;
  border: 1px solid rgba(255, 255, 255, 0.1);
}
.emergency-banner-container {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  align-items: center;
  justify-content: space-between;
}
@media (min-width: 768px) {
  .emergency-banner-container {
    flex-direction: row;
  }
}
.emergency-left-panel {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}
.emergency-alert-dot {
  width: 12px;
  height: 12px;
  background-color: #FFFFFF;
  border-radius: 50%;
  flex-shrink: 0;
  animation: pulse-ring-white 1.5s infinite;
}
@keyframes pulse-ring-white {
  0% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.8); }
  70% { box-shadow: 0 0 0 10px rgba(255, 255, 255, 0); }
  100% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0); }
}
.emergency-banner-text {
  text-align: left;
}
.emergency-dial-btn {
  box-shadow: var(--shadow-md);
  transition: all 0.3s ease;
}
.emergency-dial-btn:hover {
  transform: translateY(-2px) scale(1.02);
  box-shadow: var(--shadow-lg);
}

/* Extra utility classes for modal dialogs and details popup */
#dentist-modal-overlay {
  z-index: 3100;
}
#intake-modal-overlay {
  z-index: 3200;
}
#intake-success-overlay {
  z-index: 3300;
}

/* Responsive Form Grids and Modals Optimization */
.modal-content {
  max-height: 90vh;
  overflow-y: auto;
}
@media (max-width: 576px) {
  .modal-content {
    padding: 1.25rem 1.5rem;
  }
}
.form-grid-2col {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-md);
}
@media (min-width: 576px) {
  .form-grid-2col {
    grid-template-columns: repeat(2, 1fr);
  }
}


