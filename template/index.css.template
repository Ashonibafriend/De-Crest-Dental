/* Visual drag-split slider styling */
.ba-container {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 10;
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  user-select: none;
  cursor: ew-resize;
  border: 1px solid var(--color-border);
}

.ba-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-position: center;
  background-size: cover;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ba-before-img {
  z-index: 10;
}

.ba-after-img {
  z-index: 20;
  width: 100%;
  height: 100%;
  clip-path: polygon(50% 0, 100% 0, 100% 100%, 50% 100%); /* Standard right-side reveals clip path */
}

.ba-image img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  pointer-events: none;
}

.ba-vector-clean {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  font-family: var(--font-heading);
  font-size: 1.5rem;
  font-weight: 700;
}

.before-clean-fill {
  background: linear-gradient(135deg, #E2E8F0 0%, #CBD5E1 100%);
  color: #64748B;
}

[data-theme="dark"] .before-clean-fill {
  background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%);
  color: #475569;
}

.after-clean-fill {
  background: linear-gradient(135deg, #CFFAFE 0%, #A5F3FC 100%);
  color: #0891B2;
}

[data-theme="dark"] .after-clean-fill {
  background: linear-gradient(135deg, #083344 0%, #155e75 100%);
  color: #22d3ee;
}

/* Side indicator badges */
.ba-badge {
  position: absolute;
  top: 10px;
  background-color: rgba(15, 23, 42, 0.7);
  backdrop-filter: blur(4px);
  color: #FFFFFF;
  padding: 0.15rem 0.5rem;
  font-size: 0.72rem;
  border-radius: var(--radius-xs);
  font-weight: 600;
  pointer-events: none;
  font-family: var(--font-heading);
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.ba-badge-before {
  left: 10px;
  z-index: 15;
}

.ba-badge-after {
  right: 10px;
  z-index: 25;
}

/* Dragging control bar overlays */
.ba-handle {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 4px;
  background-color: #FFFFFF;
  z-index: 30;
  transform: translateX(-50%);
  pointer-events: none;
}

.ba-handle-btn {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background-color: var(--color-primary);
  border: 3px solid #FFFFFF;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-md);
}

.ba-handle-btn svg {
  width: 14px;
  height: 14px;
}

